msgid ":attr:`job.host-vars`"
msgstr ":attr:`job.host-vars`"

#: ../../<reno.sphinxext current branch>:577
msgid ":attr:`job.irrelevant-files`"
msgstr ":attr:`job.irrelevant-files`"

